# ForgeCLI environment variables
# Copy this file to `.env` and adjust as needed.

# General
FORGECLI_LOG_LEVEL=INFO
FORGECLI_CONFIG_PATH=
FORGECLI_DATA_DIR=

# AI Provider API Keys
# The router (`forge model auto`) reads these env vars to decide which
# providers have credentials available. Set at least one to leave the
# "mock" fallback behind.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
GEMINI_API_KEY=           # alias for GOOGLE_API_KEY
MISTRAL_API_KEY=
GROQ_API_KEY=
OPENROUTER_API_KEY=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=

# Provider defaults
FORGECLI_DEFAULT_PROVIDER=auto
FORGECLI_DEFAULT_MODEL=
FORGECLI_MAX_TOKENS=8192
FORGECLI_TEMPERATURE=0.2

# HTTP / network
FORGECLI_HTTP_TIMEOUT=60
FORGECLI_HTTP_RETRIES=3
FORGECLI_USER_AGENT=forgecli/0.1

# Git
FORGECLI_GIT_USER_NAME=
FORGECLI_GIT_USER_EMAIL=
FORGECLI_GIT_DEFAULT_BRANCH=main

# Memory / Local DB
FORGECLI_DB_PATH=
FORGECLI_HISTORY_LIMIT=1000

# Plugins
FORGECLI_PLUGINS_DIR=

# Graphify (https://graphifylabs.ai/) — optional, enables `forge graph ...`
# Install with:  uv tool install graphifyy
FORGECLI_GRAPHIFY_BIN=graphify
FORGECLI_GRAPHIFY_TIMEOUT=600

# Ponytail (https://ponytail.dev/) prompt optimizer.
# ForgeCLI ships the ruleset in-process; if a `ponytail` binary is on
# PATH (some installs ship one), it will be used automatically when
# `forge optimizer set ... --backend cli` is configured.
FORGECLI_PONYTAIL_BIN=ponytail
FORGECLI_PONYTAIL_TIMEOUT=30
# One of: off | lite | full | ultra
FORGECLI_PROMPT_OPTIMIZER__INTENSITY=lite
FORGECLI_PROMPT_OPTIMIZER__ENABLED=true
FORGECLI_PROMPT_OPTIMIZER__BACKEND=ruleset
