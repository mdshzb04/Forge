{
    "version": "0.1.0",
    "description": "AI-first developer operating system — PromptForge built-in, Forge graph optional.",
    "homepage": "https://github.com/forgecli/forgecli",
    "license": "MIT",
    "depends": "python",
    "notes": "Run `forge init` after installation to complete setup. PromptForge is built-in. For Forge graph, run: uv tool install forge graph",
    "url": "https://files.pythonhosted.org/packages/source/f/forgecli/forgecli-0.1.0.tar.gz#download",
    "hash": "REPLACE_WITH_REAL_SHA256",
    "bin": "forge.exe",
    "checkver": "github",
    "autoupdate": {
        "url": "https://pypi.org/pypi/forgecli/json",
        "extract": "$version"
    },
    "env_add_path": "python_install\\Scripts",
    "post_install": "pip install --upgrade forgecli && forge init"
}
